# Generated JWT keys
jwt-keys/
*.pem

# Local env overrides
.env
.env.local

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store

# Logs & temp
*.log
tmp/

# Local databases
*.db

# Node modules (if accidentally installed here)
node_modules/

